{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information, settings, and API keys.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "geminiKey": { "type": "string" },
            "groqKey": { "type": "string" },
            "groqKeys": {
              "type": "array",
              "items": { "type": "string" }
            },
            "openaiKey": { "type": "string" },
            "titleLengthChars": { "type": "number" },
            "keywordCount": { "type": "number" },
            "keywordStyle": { "type": "string" },
            "titleTone": { "type": "string" }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "AssetHistory": {
      "title": "Asset History",
      "description": "Stores the processing history of assets for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": { "type": "string" },
        "batchId": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "error": { "type": "string" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "fileName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles and settings."
    },
    "/users/{userId}/history/{assetId}": {
      "schema": { "$ref": "#/entities/AssetHistory" },
      "description": "Processing history for a specific user."
    }
  }
}
